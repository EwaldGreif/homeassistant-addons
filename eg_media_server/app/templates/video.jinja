<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Video {{ title }}</title>
  <style>
    html, body { margin: 0px; padding: 0px; height: 100%; overflow: hidden; }
    body { font-family: sans-serif; text-align: center; }
    h1 { font-size: 1em; margin: 0px; }
    p { margin: 2px; }
    video { width: 100%; max-height: 80vh; aspect-ratio: 16 / 9; margin: 0px auto; display: block; object-fit: contain; }
  </style>
  {% if isHls %}
	<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  {% endif %}

</head>
<body>
  <h1>Video {{ title }}</h1>
  <p><button onclick="history.back()">Zurück zum Verzeichnis</button>
  <button id="play" onclick="togglePlay()">Play</button>
  Speed <input type="number" id="speed" value="1" min="1" max="4" step="1" onchange="speed()">
  <button id="backward" onclick="backward()">Backward</button>
  <button id="forward" onclick="forward()">Forward</button>
  <button id="mute" onclick="toggleMute()">Mute</button></p>
  <button id="controls" onclick="toggleControls()">Show Controls</button></p>
  {% if mime.startswith('video/') %}
    <video id="video">
      <source src="{{ source }}" type="{{ mime }}">
      Ihr Browser unterstützt dieses Video nicht.
    </video>
  {% else %}
    <video id="video"></video>
  {% endif %}

  <script>
    document.getElementById('play').focus();
    const video = document.getElementById("video");
    {% if isHls %}
        const videoSource = "{{ source }}";
        if (Hls.isSupported()) {
          const hls = new Hls();
          hls.loadSource(videoSource);
          hls.attachMedia(video);
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = videoSource;
        } else {
          console.error('Dein Browser unterstützt HLS nicht.');
        }
    {% endif %}

    function togglePlay() {
      const btn = document.getElementById("play");
      if (video.paused) {
        video.play();
        btn.innerText = "Pause"
      } else {
        video.pause();
        btn.innerText = "Play"
      }
    }

    function speed() {
      const speed = document.getElementById("speed");
      video.playbackRate = parseFloat(speed.value);
    }

    function backward() {
      video.currentTime = Math.max(0, video.currentTime - 10);
    }

    function forward() {
      video.currentTime = Math.min(video.duration, video.currentTime + 10);
    }

    function toggleMute() {
      const btn = document.getElementById("mute");
      if (video.muted) {
        video.muted = false;
        btn.innerText = "Mute"
      } else {
        video.muted = true;
        btn.innerText = "Unmute"
      }
    }

    function toggleControls() {
      const btn = document.getElementById("controls");
      if (video.controls) {
        video.controls = false;
        btn.innerText = "Show Controls"
      } else {
        video.controls = true;
        btn.innerText = "Hide Controls"
      }
    }
  </script>
</body>
</html>
