<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <title>Verzeichnis {{ dir }}</title>
  <style>
    html, body { margin: 0px; padding: 0px; height: 100%; overflow: auto; }
    body { font-family: sans-serif; }
    h1 { font-size: 1em; margin: 0px; }
    p { margin: 2px; }
    a:focus {
        outline: 3px solid orange;
        background-color: #222;
        color: #fff;
    }  
  </style>
</head>
<body>
  <h1>{{ dir }}</h1>

  {% if parent_dir %}
    <p><button id="back" onclick="history.back()">Eine Ebene zurück</button>
    {% if images > 1 %}
      <button id="startSlideshow" onclick="window.location.href='/slideshow?dir={{ dir }}'">Diashow starten</button>
    {% endif %}</p>
  {% endif %}

  <ul id="list">
    {% if images > 1 %}
      <li>{{ images }} Bilder</li>
    {% endif %}
    {% for name, type, href in entries %}
      {% if type == "folder" %}
        <li><a href="{{ href }}">{{ name }}</a></li>
      {% elif type == "playlist" %}
        <li><a href="{{ href }}">{{ name }}</a></li>
      {% elif type == "video" %}
        <li><a href="/video?href={{ href }}">{{ name }}</a></li>
      {% elif type == "audio" %}
        <li><a href="/audio?href={{ href }}">{{ name }}</a></li>
      {% elif type == "image" %}
        {# <li><a href="{{ href }}">{{ name }}</a></li> #}
      {% else %}
        <li><a href="{{ href }}">{{ name }}</a></li>
      {% endif %}
    {% endfor %}
  </ul>

  <script>
    {% if images > 0 %}
    document.getElementById("startSlideshow").focus();
    {% else %}
    if (document.referrer) {
      const list = document.getElementById('list');
      const firstItem = list.querySelector('li > a');
      if (firstItem) {
        firstItem.focus();
      }      
    } else {
      document.getElementById("back").focus();
    }
    {% endif %}
  </script>
</body>
</html>
